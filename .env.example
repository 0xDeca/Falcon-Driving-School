# =============================================================================
# Falcon Driving School - Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values.
# Get Supabase credentials from: https://supabase.com/dashboard/project/_/settings/api
# =============================================================================

# --- Supabase (Required) ---
# Project URL and anon key from Supabase dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- App URL (Required for auth redirects) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Resend (Transactional Emails) ---
# Sign up at https://resend.com to get your API key
RESEND_API_KEY=your-resend-api-key

# --- OPay (Nigerian Payment Gateway) ---
# Contact OPay merchant services to obtain these
OPAY_API_KEY=your-opay-api-key
OPAY_MERCHANT_ID=your-merchant-id

# --- Stripe (International Card Payments) ---
# Get keys from https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_SECRET_KEY=your-stripe-secret-key
# Get webhook secret from Stripe Dashboard > Developers > Webhooks
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
